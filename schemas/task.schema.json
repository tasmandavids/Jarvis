{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/task.schema.json",
  "title": "Task",
  "description": "Row shape for public.tasks",
  "type": "object",
  "required": ["id", "status", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "headline": { "type": "string" },
    "description": { "type": "string" },
    "responsible": {
      "type": "string",
      "format": "uuid",
      "description": "Agent UUID from config/agents/*.json supabase_id"
    },
    "status": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Status labels (e.g. queued, in-progress, done)"
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
