{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/integration.schema.json",
  "title": "Integration",
  "description": "External service connection metadata (secrets via env vars)",
  "type": "object",
  "required": ["id", "name", "type", "status"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["notion", "n8n", "supabase", "vercel", "github", "slack", "anthropic", "openai", "google"]
    },
    "status": {
      "type": "string",
      "enum": ["connected", "disconnected", "error"]
    },
    "env_keys": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Environment variable names required for this integration"
    },
    "webhook_url": { "type": "string" },
    "docs_url": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
