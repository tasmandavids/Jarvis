{
  "name": "cypher-desktop",
  "version": "1.0.0",
  "description": "CYPHER — Personal Intelligence System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "dist": "bash -lc 'cd ../.. && npm run build && cp apps/dashboard/.env.local apps/dashboard/.next/standalone/apps/dashboard/.env.local && cp -r apps/dashboard/.next/static apps/dashboard/.next/standalone/apps/dashboard/.next/static && cp -r apps/dashboard/public apps/dashboard/.next/standalone/apps/dashboard/public 2>/dev/null || true && cd apps/desktop && electron-builder --mac --publish never'"
  },
  "build": {
    "appId": "com.tasmandavids.cypher",
    "productName": "CYPHER",
    "electronVersion": "42.5.1",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "CYPHER Installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../dashboard/.next/standalone",
        "to": "dashboard",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../config",
        "to": "config-root/config",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../prompts",
        "to": "config-root/prompts",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "42.5.1",
    "electron-builder": "^26.15.3"
  }
}
