{
  "name": "cypher-desktop",
  "version": "1.0.0",
  "description": "CYPHER — Personal Intelligence System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "dist": "bash -lc 'cd ../.. && npm run build && cp apps/web/.env.local apps/web/.next/standalone/apps/web/.env.local && rm -rf apps/web/.next/standalone/apps/web/.next/static && cp -r apps/web/.next/static apps/web/.next/standalone/apps/web/.next/static && rm -rf apps/web/.next/standalone/apps/web/public && cp -r apps/web/public apps/web/.next/standalone/apps/web/public 2>/dev/null || true && cd apps/desktop && electron-builder --mac --publish never'"
  },
  "build": {
    "appId": "com.tasmandavids.cypher",
    "productName": "CYPHER",
    "electronVersion": "42.5.1",
    "afterPack": "./afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "CYPHER Installer"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "app",
        "filter": [
          "**/*",
          "**/.*",
          "**/.next/**",
          "**/node_modules/**"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "42.5.1",
    "electron-builder": "^26.15.3"
  }
}
