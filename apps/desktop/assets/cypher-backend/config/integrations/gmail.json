{
  "id": "gmail",
  "name": "Gmail",
  "status": "configured",
  "owner_agent": "cypher",
  "auth": {
    "type": "oauth2",
    "scopes": [
      "gmail.readonly",
      "gmail.send",
      "gmail.modify"
    ],
    "env_key": "GMAIL_OAUTH_TOKEN"
  },
  "webhooks": {
    "type": "pubsub",
    "topic": "projects/${GOOGLE_PROJECT_ID}/topics/gmail-push",
    "env_key": "GMAIL_WEBHOOK_SECRET"
  },
  "actions": [
    "read_inbox",
    "send_message",
    "label_message",
    "archive",
    "draft_reply"
  ],
  "approval_required": [
    "send_message"
  ],
  "supabase_table": "comms_log"
}