# ─── Jarvis Command Centre ───────────────────────────────────────────────────
# Copy to .env.local (apps/dashboard) or root .env for local dev.
# Never commit real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Notion
NOTION_API_KEY=
NOTION_COMMAND_CENTRE_PAGE_ID=

# n8n
N8N_WEBHOOK_BASE_URL=https://your-n8n.example.com/webhook
N8N_API_KEY=

# Slack (https://api.slack.com/apps)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_COMMAND_CENTRE_CHANNEL_ID=
SLACK_ALERTS_CHANNEL_ID=
SLACK_AGENT_RUNS_CHANNEL_ID=

# GitHub (for agent actions & workflow triggers)
GITHUB_TOKEN=
GITHUB_REPO=tasmandavids/Jarvis

# Vercel — powers the Infra panel on the CYPHER dashboard via /api/sync/vercel
# Token: vercel.com/account/tokens · Project/Team ID are optional scoping filters
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Stripe — powers the Finance panel via /api/sync/stripe (balance/net30d/last payout only —
# burn/runway need Xero and aren't reported as live yet)
STRIPE_SECRET_KEY=

# Xero — powers burn/cash/runway on the Finance panel via /api/sync/xero.
# App: developer.xero.com/app/manage · needs a one-time consent at /api/auth/xero/start
# after these are set (redirect URI must be registered on the app: <origin>/api/auth/xero/callback)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Shared secret for connector sync routes (n8n cron -> POST /api/sync/*)
SYNC_SECRET=
