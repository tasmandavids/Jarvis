# ─── Jarvis Command Centre ───────────────────────────────────────────────────
# Copy to .env.local (apps/dashboard) or root .env for local dev.
# Never commit real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Notion
NOTION_API_KEY=
NOTION_COMMAND_CENTRE_PAGE_ID=

# n8n
N8N_WEBHOOK_BASE_URL=https://your-n8n.example.com/webhook
N8N_API_KEY=

# GitHub (for agent actions & workflow triggers)
GITHUB_TOKEN=
GITHUB_REPO=your-org/Jarvis

# Vercel (optional — usually set in Vercel dashboard)
VERCEL_TOKEN=
