{
  "id": "xero",
  "name": "Xero",
  "status": "configured",
  "owner_agent": "sable",
  "auth": {
    "type": "oauth2",
    "scopes": [
      "accounting.transactions",
      "accounting.reports.read"
    ],
    "env_key": "XERO_ACCESS_TOKEN"
  },
  "actions": [
    "list_invoices",
    "get_cashflow",
    "list_expenses",
    "get_balance_sheet"
  ],
  "approval_required": [
    "create_invoice",
    "mark_paid"
  ],
  "sync_schedule": "0 8 * * *"
}