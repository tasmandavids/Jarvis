{
  "id": "stripe",
  "name": "Stripe",
  "status": "configured",
  "owner_agent": "sable",
  "auth": {
    "type": "api_key",
    "env_key": "STRIPE_SECRET_KEY"
  },
  "webhooks": {
    "endpoint": "/api/webhooks/stripe",
    "env_key": "STRIPE_WEBHOOK_SECRET",
    "events": [
      "payment_intent.succeeded",
      "invoice.payment_failed",
      "customer.subscription.updated"
    ]
  },
  "actions": [
    "read_payouts",
    "read_mrr",
    "read_invoices",
    "list_customers"
  ],
  "approval_required": [
    "issue_refund",
    "cancel_subscription"
  ],
  "read_only": false
}