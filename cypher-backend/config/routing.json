{
  "version": "2.0.0",
  "default_agent_id": "cypher",
  "routes": [
    {
      "intent": "orchestrate",
      "agent_id": "cypher",
      "fallback_agent_id": "jarvis-claude",
      "description": "Planning, delegation, briefings, multi-step reasoning"
    },
    {
      "intent": "infra",
      "agent_id": "orion",
      "fallback_agent_id": "cypher",
      "description": "Server health, Vercel, GitHub CI, deployments"
    },
    {
      "intent": "finance",
      "agent_id": "sable",
      "fallback_agent_id": "cypher",
      "description": "MRR, cashflow, invoices, Stripe, Xero"
    },
    {
      "intent": "personal",
      "agent_id": "vesper",
      "fallback_agent_id": "cypher",
      "description": "Health, calendar, reminders, personal tasks"
    },
    {
      "intent": "ads",
      "agent_id": "morrigan",
      "fallback_agent_id": "cypher",
      "description": "Campaigns, ROAS, creative, funnel analysis"
    },
    {
      "intent": "research",
