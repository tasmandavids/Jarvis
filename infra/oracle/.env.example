# CYPHER Oracle box — environment variables
# Copy to .env and fill in. Never commit .env.

# ── Domain ───────────────────────────────────────────────────────────────────
# The public hostname of your Oracle box.
# Either a subdomain (n8n.yourdomain.com) or the raw IP.
N8N_HOST=n8n.yourdomain.com

# ── n8n auth ─────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change_me_strong_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── CYPHER gateway webhook secret ────────────────────────────────────────────
# n8n workflows POST to /api/cypher/event on the Vercel gateway.
# This must match CYPHER_WEBHOOK_SECRET in Vercel env vars.
CYPHER_WEBHOOK_SECRET=change_me_webhook_secret

# ── Supabase (for n8n workflows that write directly to Supabase) ─────────────
SUPABASE_URL=https://hwyokoiqjynmcpuypwmf.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
